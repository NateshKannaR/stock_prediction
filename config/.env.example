APP_NAME=Benx Quant Trading Platform
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3001,http://localhost:3001

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=benx_quant
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

DEFAULT_ADMIN_EMAIL=admin@benx.local
DEFAULT_ADMIN_PASSWORD=change-me-now

UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_ACCESS_TOKEN=
UPSTOX_REDIRECT_URI=
UPSTOX_AUTH_URL=https://api-v2.upstox.com/login/authorization/dialog
UPSTOX_TOKEN_URL=https://api-v2.upstox.com/login/authorization/token
UPSTOX_API_BASE_URL=https://api.upstox.com
UPSTOX_HFT_BASE_URL=https://api-hft.upstox.com
